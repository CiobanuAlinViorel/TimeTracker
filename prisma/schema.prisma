generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  username      String          @unique
  email         String          @unique
  password      String
  dailyWorkTime DailyWorkTime[]
}

model DailyWorkTime {
  id         String   @id @default(cuid())
  date       DateTime
  start_hour DateTime
  end_hour   DateTime?
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
}
